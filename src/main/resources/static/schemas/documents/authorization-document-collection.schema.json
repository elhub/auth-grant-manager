{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Authorization Document Collection",
  "description": "Schema for returning a collection of authorization documents.",
  "type": "object",
  "properties": {
    "data": {
      "description": "An array of authorization document resource objects.",
      "type": "array",
      "items": {
        "$ref": "authorization-document-resource.schema.json#/properties/data"
      },
      "uniqueItems": true
    },
    "links": {
      "description": "Link members related to the collection (e.g. pagination).",
      "$ref": "../json-api-framework.schema.json#/$defs/topLevelLinks",
      "examples": [
        {
          "self": "/access/v0/authorization-documents"
        }
      ]
    },
    "meta": {
      "allOf": [
        { "$ref": "../json-api-framework.schema.json#/$defs/topLevelMeta" },
        {
          "type": "object",
          "properties": {
            "totalItems": {
              "type": "integer",
              "description": "Total number of items matching the query."
            },
            "totalPages": {
              "type": "integer",
              "description": "Total number of pages."
            },
            "page": {
              "type": "integer",
              "description": "Current zero-based page number."
            },
            "pageSize": {
              "type": "integer",
              "description": "Number of items per page."
            }
          },
          "required": ["totalItems", "totalPages", "page", "pageSize"]
        }
      ]
    }
  },
  "required": [
    "data",
    "links",
    "meta"
  ]
}
